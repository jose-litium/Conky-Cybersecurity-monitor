#!/usr/bin/env bash
# shellcheck disable=SC2034
set -euo pipefail
IFS=$'\n\t'

# ============================================================================
# Conky Cybersecurity Monitor
# Script de instalación, configuración y gestión de Conky con monitorización
# de seguridad en tiempo real (RKHunter, sensores, red) y restauración del sistema.
#
# Autor original: Jose Diaz (jose-litium)
#   GitHub:   https://github.com/jose-litium
#   LinkedIn: https://www.linkedin.com/in/josemmanueldiaz/
#   Email:    jmmorenod@hotmail.es
#   Location: Remote / Ho Chi Minh City
#
# Versión endurecida: 2026-06-01
#   - Endurecimiento de sudoers (Cmnd_Alias + validación visudo)
#   - Cumplimiento ShellCheck + set -euo pipefail
#   - Servicios systemd con sandboxing (ProtectSystem, PrivateTmp, NoNewPrivileges)
#   - Reemplazo de 'netstat' por 'ss' (locale-independiente)
#   - Manejo seguro de archivos temporales (mktemp + trap cleanup)
#   - Detección de VPN sin depender de nmcli
#   - Logging persistente con marca de tiempo
# ============================================================================

########################################
# Constantes globales (readonly)
########################################

readonly SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_PATH="$(readlink -f "$0")"
readonly INSTALL_DIR="$HOME/.local/conky_app"
readonly LOGFILE="/tmp/conky_monitor_$$.log"
readonly SUDOERS_FILE="/etc/sudoers.d/conky-monitor"

########################################
# Colores terminal
########################################

readonly BLUE='\033[1;34m'
readonly CYAN='\033[1;36m'
readonly GREEN='\033[1;32m'
readonly MAGENTA='\033[1;35m'
readonly YELLOW='\033[1;33m'
readonly WHITE='\033[1;37m'
readonly RED='\033[1;31m'
readonly NC='\033[0m'

########################################
# Trap global de limpieza segura
########################################

cleanup() {
    local exit_code=$?
    log "Script finaliza con código: $exit_code"
    # Limpieza best-effort de artefactos temporales sensibles
    rm -f /tmp/rkhunter_result.* \
          /tmp/rkhunter_warnings*.txt \
          /tmp/rkhunter_status.txt \
          /tmp/cpu_temp.txt \
          /tmp/google-chrome-stable_current_amd64.deb 2>/dev/null || true
    exit "$exit_code"
}
trap cleanup EXIT INT TERM

########################################
# Logging con marca de tiempo
########################################

log() {
    echo "$(date '+%Y-%m-%d %H:%M:%S') - $*" >> "$LOGFILE" 2>/dev/null || true
}

########################################
# Bootstrap: asegurar 'dialog' disponible
########################################

bootstrap_dialog() {
    if ! command -v dialog >/dev/null 2>&1; then
        echo -e "${YELLOW}[BOOTSTRAP] Instalando 'dialog'...${NC}"
        if command -v apt >/dev/null 2>&1; then
            sudo apt update && sudo apt install -y dialog
        else
            echo -e "${RED}Error: 'dialog' no está instalado y no se encontró apt.${NC}" >&2
            exit 1
        fi
    fi
}

########################################
# Wrappers dialog
########################################

dconfirm() {
    dialog --clear --yesno "$1" 8 70
    return $?
}

dmsg() {
    dialog --clear --msgbox "$1" 12 75
}

dmenu() {
    local menu_title="$1"
    shift
    local -a menu_options=("$@")
    local choice
    choice=$(dialog --clear --backtitle "Conky Cybersecurity Monitor" \
        --title "$menu_title" \
        --menu "Elige una opción:" 24 75 18 "${menu_options[@]}" 2>&1 >/dev/tty) || return 1
    echo "$choice"
}

########################################
# Sudo: adquirir y mantener vivo
########################################

acquire_sudo() {
    dmsg "Se requieren privilegios de administrador para instalar paquetes."
    if ! sudo -v; then
        dmsg "No se pudieron obtener privilegios sudo. Saliendo..."
        log "ERROR: sudo acquisition failed"
        exit 1
    fi
    # Keep-alive en background para instalaciones largas
    ( while true; do sudo -n true 2>/dev/null; sleep 50; kill -0 "$$" 2>/dev/null || exit; done ) &
}

########################################
# Sudoers ENDURECIDO (Cmnd_Alias + PASSWD para sensibles)
########################################

setup_sudoers() {
    log "Configurando sudoers endurecido en $SUDOERS_FILE"

    sudo tee "$SUDOERS_FILE" > /dev/null <<'EOF'
# Conky Cybersecurity Monitor - Mínimos privilegios
# Generado automáticamente. No editar a mano.

Cmnd_Alias CONKY_NET     = /usr/bin/netstat, /usr/bin/ss, /usr/bin/hostname
Cmnd_Alias CONKY_LOGS    = /usr/bin/journalctl
Cmnd_Alias CONKY_SENSORS = /usr/bin/sensors
Cmnd_Alias CONKY_CURL    = /usr/bin/curl
Cmnd_Alias CONKY_LSOF    = /usr/bin/lsof

# RKHunter y chmod/usermod REQUIEREN contraseña (no son NOPASSWD por seguridad)
Cmnd_Alias CONKY_RKHUNTER = /usr/bin/rkhunter --update, \
                            /usr/bin/rkhunter --propupd, \
                            /usr/bin/rkhunter --check --sk
Cmnd_Alias CONKY_CHMOD    = /usr/bin/chmod +r /var/log/rkhunter.log, \
                            /usr/bin/chmod 644 /var/log/rkhunter.log
Cmnd_Alias CONKY_USERMOD  = /usr/sbin/usermod -aG adm *

__USER__ ALL=(ALL) NOPASSWD: CONKY_NET, CONKY_LOGS, CONKY_SENSORS, CONKY_CURL, CONKY_LSOF
__USER__ ALL=(ALL) PASSWD:   CONKY_RKHUNTER, CONKY_CHMOD, CONKY_USERMOD
EOF

    sudo sed -i "s|__USER__|$USER|g" "$SUDOERS_FILE"
    sudo chmod 0440 "$SUDOERS_FILE"

    if sudo visudo -c -f "$SUDOERS_FILE" &>/dev/null; then
        log "Sudoers validado y aplicado para usuario $USER."
        echo -e "${GREEN}Sudoers configurado con éxito.${NC}"
    else
        log "ERROR: validación sudoers falló, revirtiendo."
        sudo rm -f "$SUDOERS_FILE"
        dmsg "Error de sintaxis en sudoers. Se revirtieron los cambios."
        return 1
    fi
}

########################################
# Checks de sistema
########################################

check_user_systemd() {
    if ! systemctl --user 2>/dev/null; then
        dmsg "Systemd a nivel de usuario no disponible.\nUsa Ubuntu 18.04+ con entorno de escritorio."
        log "ERROR: user systemd not available"
        exit 1
    fi
}

check_install() {
    local pkg="$1"
    if dpkg -s "$pkg" &>/dev/null; then
        echo -e "${GREEN}$pkg ya está instalado.${NC}"
        log "$pkg already installed."
        return 0
    else
        echo -e "${CYAN}$pkg no está instalado.${NC}"
        if dconfirm "¿Deseas instalar $pkg?"; then
            if sudo apt install -y "$pkg"; then
                log "$pkg installed."
                return 0
            else
                log "ERROR installing $pkg."
                dmsg "Error al instalar $pkg. Revisa la red o repositorios."
                return 1
            fi
        else
            echo -e "${RED}Omitiendo $pkg (afectará funcionalidad).${NC}"
            log "User skipped $pkg."
            return 1
        fi
    fi
}

########################################
# Script auxiliar RKHunter (hardened)
########################################

create_rkhunter_scan_script() {
    local script_path="$INSTALL_DIR/rkhunter_scan.sh"
    cat <<'EOF' > "$script_path"
#!/usr/bin/env bash
set -uo pipefail

# Wrapper seguro para RKHunter invocado desde Conky
readonly WARN_FILE="/tmp/rkhunter_warnings_$$.txt"
readonly RESULT_FILE
RESULT_FILE="$(mktemp /tmp/rkhunter_result.XXXXXX)"

cleanup() { rm -f "$RESULT_FILE" 2>/dev/null || true; }
trap cleanup EXIT

sudo /usr/bin/rkhunter --update     >/dev/null 2>&1 || true
sudo /usr/bin/rkhunter --propupd    >/dev/null 2>&1 || true
sudo /usr/bin/rkhunter --check --sk >"$RESULT_FILE" 2>/dev/null || true

grep -iE "(warning|alert|suspect)" "$RESULT_FILE" > "$WARN_FILE" 2>/dev/null || true

# Detección de cambios para UI de Conky
if [[ -f /tmp/rkhunter_warnings_prev.txt ]]; then
    if ! cmp -s "$WARN_FILE" /tmp/rkhunter_warnings_prev.txt; then
        cp "$WARN_FILE" /tmp/rkhunter_warnings_prev.txt 2>/dev/null || true
        echo "CHANGED" > /tmp/rkhunter_status.txt
    else
        echo "UNCHANGED" > /tmp/rkhunter_status.txt
    fi
else
    cp "$WARN_FILE" /tmp/rkhunter_warnings_prev.txt 2>/dev/null || true
    if [[ -s "$WARN_FILE" ]]; then
        echo "INITIAL_WITH_ALERTS" > /tmp/rkhunter_status.txt
    else
        echo "INITIAL_CLEAN" > /tmp/rkhunter_status.txt
    fi
fi

cp "$WARN_FILE" /tmp/rkhunter_warnings.txt 2>/dev/null || touch /tmp/rkhunter_warnings.txt
exit 0
EOF
    chmod 700 "$script_path"
    log "rkhunter_scan.sh creado en $script_path"
}

########################################
# Configuración de sensores (lm-sensors)
########################################

configure_sensors() {
    echo -e "${BLUE}Configurando sensores de hardware (lm-sensors)...${NC}"
    if command -v sensors >/dev/null 2>&1; then
        if dconfirm "¿Ejecutar sensors-detect para configurar sensores automáticamente?"; then
            echo -e "${BLUE}Ejecutando sensors-detect...${NC}"
            if yes | sudo sensors-detect >> "$LOGFILE" 2>&1; then
                sudo modprobe -a coretemp it87 2>/dev/null || true
                echo -e "${GREEN}Configuración de sensores completada.${NC}"
                log "sensors-detect OK."
            else
                log "WARNING: sensors-detect con errores."
                dmsg "sensors-detect finalizó con advertencias. Revisa el log."
            fi
        else
            echo -e "${YELLOW}Saltando sensors-detect.${NC}"
            log "sensors-detect skipped."
        fi
    else
        echo -e "${RED}lm-sensors no instalado. Saltando configuración.${NC}"
        log "lm-sensors not available."
    fi
}

########################################
# Monitor de temperatura (script + service)
########################################

create_temp_monitor_script() {
    local script_path="$INSTALL_DIR/temp_monitor.sh"
    cat <<'EOF' > "$script_path"
#!/usr/bin/env bash
set -uo pipefail

# Monitor robusto de temperatura CPU
readonly TEMP_FILE="/tmp/cpu_temp.txt"
readonly MAX_SAFE_TEMP=95

while true; do
    local raw
    raw="$(sensors 2>/dev/null \
            | grep -Eo '\+[0-9]+(\.[0-9]+)?°C' \
            | head -n1 \
            | tr -d '+°C' || true)"

    if [[ -n "$raw" && "$raw" =~ ^[0-9]+(\.[0-9]+)?$ ]]; then
        if awk "BEGIN {exit !($raw > $MAX_SAFE_TEMP)}"; then
            echo ">${MAX_SAFE_TEMP}°C" > "$TEMP_FILE"
        else
            printf "%.1f°C\n" "$raw" > "$TEMP_FILE"
        fi
    else
        echo "N/A" > "$TEMP_FILE"
    fi
    sleep 10
done
EOF
    chmod 700 "$script_path"
    log "temp_monitor.sh creado en $script_path"
}

install_temp_monitor_service() {
    mkdir -p ~/.config/systemd/user
    cat > ~/.config/systemd/user/temp_monitor.service <<EOL
[Unit]
Description=CPU Temperature Monitor for Conky Cybersecurity Dashboard
After=default.target
Wants=default.target

[Service]
Type=simple
ExecStart=/usr/bin/env bash "$INSTALL_DIR/temp_monitor.sh"
Restart=on-failure
RestartSec=10
PrivateTmp=true
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/tmp

[Install]
WantedBy=default.target
EOL

    systemctl --user daemon-reload
    if systemctl --user enable --now temp_monitor.service 2>/dev/null; then
        echo -e "${GREEN}Servicio de monitor de temperatura activo.${NC}"
        log "temp_monitor.service enabled & started."
    else
        log "WARNING: temp_monitor.service no pudo iniciarse."
        dmsg "No se pudo iniciar el servicio de temperatura.\nInícialo tras sesión gráfica."
    fi
}

########################################
# RKHunter automático (systemd system)
########################################

install_rkhunter_service() {
    echo -e "${BLUE}Instalando servicio automático de RKHunter...${NC}"

    sudo mkdir -p /usr/local/bin
    sudo tee /usr/local/bin/rkhunter-auto-scan.sh > /dev/null <<'EOL'
#!/usr/bin/env bash
set -uo pipefail

readonly WARN_FILE="/tmp/rkhunter_warnings.txt"
readonly RESULT_FILE
RESULT_FILE="$(mktemp)"
cleanup() { rm -f "$RESULT_FILE" 2>/dev/null || true; }
trap cleanup EXIT

/usr/bin/rkhunter --update     >/dev/null 2>&1 || true
/usr/bin/rkhunter --propupd    >/dev/null 2>&1 || true
/usr/bin/rkhunter --check --sk >"$RESULT_FILE" 2>/dev/null || true

grep -iE "(warning|alert|suspect)" "$RESULT_FILE" > "$WARN_FILE" 2>/dev/null \
    || touch "$WARN_FILE"
exit 0
EOL
    sudo chmod 750 /usr/local/bin/rkhunter-auto-scan.sh

    sudo tee /etc/systemd/system/rkhunter-auto.service > /dev/null <<'EOL'
[Unit]
Description=Automatic RKHunter Security Scan for Conky Monitor
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
ExecStart=/usr/local/bin/rkhunter-auto-scan.sh
RemainAfterExit=yes
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/tmp /var/log/rkhunter.log

[Install]
WantedBy=multi-user.target
EOL

    sudo tee /etc/systemd/system/rkhunter-auto.timer > /dev/null <<'EOL'
[Unit]
Description=Timer for RKHunter automatic security scans
Requires=rkhunter-auto.service

[Timer]
OnBootSec=10min
OnUnitActiveSec=6h
RandomizedDelaySec=30min
Persistent=true

[Install]
WantedBy=timers.target
EOL

    sudo systemctl daemon-reload
    if sudo systemctl enable --now rkhunter-auto.timer 2>/dev/null; then
        echo -e "${GREEN}Timer RKHunter activo (cada 6h ±30min).${NC}"
        echo -e "${YELLOW}Log de alertas: /tmp/rkhunter_warnings.txt${NC}"
        log "rkhunter-auto.timer enabled."
    else
        log "WARNING: rkhunter-auto.timer no pudo activarse."
        dmsg "No se pudo activar el temporizador automático."
    fi
}

remove_rkhunter_service() {
    echo -e "${RED}Eliminando servicio y timer de RKHunter...${NC}"
    sudo systemctl disable --now rkhunter-auto.timer   2>/dev/null || true
    sudo systemctl disable --now rkhunter-auto.service 2>/dev/null || true
    sudo rm -f /etc/systemd/system/rkhunter-auto.timer
    sudo rm -f /etc/systemd/system/rkhunter-auto.service
    sudo rm -f /usr/local/bin/rkhunter-auto-scan.sh
    sudo systemctl daemon-reload
    echo -e "${GREEN}Timer y servicio RKHunter eliminados.${NC}"
    log "rkhunter-auto removed."
}

########################################
# Instalación principal de Conky
########################################

install_conky() {
    if ! dconfirm "¿Proceder con la instalación y configuración de Conky?"; then
        dmsg "Instalación abortada por el usuario."
        log "install_conky aborted."
        return 1
    fi

    check_user_systemd
    echo -e "${BLUE}Actualizando listas de paquetes...${NC}"
    sudo apt update

    local -a apps=("conky-all" "curl" "net-tools" "iproute2" "lsof"
                   "xdg-utils" "rkhunter" "lm-sensors" "nmap" "upower")
    for app in "${apps[@]}"; do
        check_install "$app" || true
    done

    configure_sensors
    create_rkhunter_scan_script

    echo -e "${BLUE}Ajustando permisos de logs de RKHunter...${NC}"
    [[ -f /var/log/rkhunter.log ]] && sudo chmod 644 /var/log/rkhunter.log 2>/dev/null || true
    sudo usermod -aG adm "$USER" 2>/dev/null || true

    echo -e "${BLUE}Configurando sudoers con mínimos privilegios...${NC}"
    setup_sudoers || dmsg "Advertencia: fallo de sudoers. Algunas funciones pedirán contraseña."

    mkdir -p ~/.config/conky
    local home_dir="$HOME"

    echo -e "${BLUE}Generando configuración de Conky...${NC}"
    # Nota: uso de 'ss' (locale-independent) en lugar de netstat + grep ESTABLECIDO
    cat > ~/.config/conky/conky.conf <<EOL
conky.config = {
    alignment = 'top_right',
    background = false,
    double_buffer = true,
    update_interval = 1,
    own_window = true,
    own_window_type = 'desktop',
    own_window_argb_visual = true,
    own_window_argb_value = 140,
    own_window_hints = 'undecorated,below,sticky,skip_taskbar,skip_pager',
    gap_x = 15,
    gap_y = 50,
    minimum_width = 420,
    minimum_height = 750,
    draw_shades = false,
    draw_borders = false,
    use_xft = true,
    default_color = 'white',
    default_outline_color = 'blue',
    override_utf8_locale = true,
};

conky.text = [[
\${exec $home_dir/.local/conky_app/rkhunter_scan.sh > /dev/null 2>&1}
\${color yellow}\${time %H:%M:%S}       Vietnam (GMT+7)
\${color cyan}\${execi 10 TZ='Europe/Madrid' date '+%H:%M:%S'}       Madrid (GMT+1)
\${color green}\${execi 10 TZ='Australia/Sydney' date '+%H:%M:%S'}       Sydney (GMT+10)
\${color magenta}\${execi 10 TZ='America/New_York' date '+%H:%M:%S'}      New York (GMT-5)

\${color magenta}------ Indicadores de Hardware ------
\${color white}CPU: \${if_match \${cpu cpu0} > 80}\${color red}\${cpu cpu0}%\${else}\${color green}\${cpu cpu0}%\${endif} \${cpubar cpu0 10,}
\${color white}RAM: \${if_match \${memperc} > 40}\${color red}\${memperc}%\${else}\${color green}\${memperc}%\${endif} \${membar 10}
\${color white}Main HDD: \${if_match \${fs_used_perc /} > 60}\${color red}\${fs_used_perc /}%\${else}\${color green}\${fs_used_perc /}%\${endif} \${fs_bar /}
\${color white}Temp. CPU: \${color red}\${execi 10 cat /tmp/cpu_temp.txt 2>/dev/null || echo "N/A"}
\${color white}Uptime: \${color green}\${uptime}

\${color magenta}------ Información de Red ------
\${color white}IP Local: \${color cyan}\${execi 10 hostname -I 2>/dev/null | cut -d' ' -f1 || echo "N/A"}
\${color white}IP Pública: \${color cyan}\${execi 600 curl -s --max-time 10 https://ifconfig.me 2>/dev/null || echo "N/A"}
\${color white}VPN: \${execi 30 bash -c 'if ip link show 2>/dev/null | grep -Eiq "^(tun|tap|ppp)"; then echo "\${color yellow}activa\${color white}"; else echo "\${color yellow}inactiva\${color white}"; fi'}
\${color white}Estado SSH: \${color yellow}\${execi 30 systemctl is-active ssh 2>/dev/null || echo "inactive"}
\${color white}Conexiones Establecidas: \${color red}\${execi 10 ss -tn state established 2>/dev/null | tail -n +2 | wc -l || echo "0"}
\${color white}Puertos Abiertos: \${color red}\${execi 10 ss -tuln 2>/dev/null | tail -n +2 | wc -l || echo "0"}

\${color magenta}------ Usuarios Conectados ------
\${color white}Usuarios: \${color cyan}\${execi 30 who 2>/dev/null | awk '{print \$1}' | sort -u | xargs || echo "Ninguno"}

\${color magenta}------ Eventos de Seguridad ------
\${color white}Eventos Recientes: \${color red}\${execi 30 journalctl -n 5 -p 3 -u ssh.service --no-pager 2>/dev/null | tail -n 5 || echo "Sin eventos"}

\${color magenta}------ Alertas de Rootkit ------
\${color white}Alertas: \${execi 600 bash -c 'if [[ -f /tmp/rkhunter_status.txt ]]; then s=\$(cat /tmp/rkhunter_status.txt); case "\$s" in CHANGED) echo "NUEVAS - /tmp/rkhunter_warnings.txt";; INITIAL_WITH_ALERTS) echo "Sí (histórico)";; INITIAL_CLEAN|UNCHANGED) if [[ -s /tmp/rkhunter_warnings.txt ]]; then echo "Sí"; else echo "0"; fi;; *) echo "Inicializando...";; esac; else echo "Inicializando..."; fi'}
\${color yellow}  *Log: \${color #CCCCCC}/tmp/rkhunter_warnings.txt

\${color magenta}------ Top 5 Procesos ------
\${color white}\${execi 5 ps -eo pid,comm,%cpu --sort=-%cpu 2>/dev/null | head -n 6 | tail -n 5 || echo "N/A"}
]];
EOL

    mkdir -p ~/.config/systemd/user
    echo -e "${BLUE}Creando servicio systemd de Conky...${NC}"
    cat > ~/.config/systemd/user/conky.service <<EOL
[Unit]
Description=Conky Cybersecurity Monitor (User Level)
After=default.target graphical-session.target
Wants=default.target

[Service]
Type=simple
ExecStart=/usr/bin/conky -b -c "$home_dir/.config/conky/conky.conf"
Restart=on-failure
RestartSec=10
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=$home_dir/.config/conky /tmp
NoNewPrivileges=true

[Install]
WantedBy=default.target
EOL

    systemctl --user daemon-reload
    if systemctl --user enable --now conky.service 2>/dev/null; then
        echo -e "${GREEN}Conky instalado y activo bajo sesión systemd de usuario.${NC}"
        log "conky.service enabled & started."
    else
        log "WARNING: conky.service no pudo iniciarse."
        dmsg "Conky instalado pero no pudo iniciarse automáticamente.\nEjecuta: systemctl --user start conky.service"
    fi

    create_temp_monitor_script
    install_temp_monitor_service
    install_rkhunter_service
}

########################################
# Desinstalación completa
########################################

uninstall_conky() {
    if ! dconfirm "¿Eliminar COMPLETAMENTE Conky, servicios, sudoers y configuración?"; then
        dmsg "Desinstalación abortada."
        return 1
    fi

    echo -e "${RED}Deteniendo servicios...${NC}"
    for svc in conky.service temp_monitor.service; do
        if [[ -f ~/.config/systemd/user/$svc ]]; then
            systemctl --user stop "$svc"    2>/dev/null || true
            systemctl --user disable "$svc" 2>/dev/null || true
            rm -f ~/.config/systemd/user/"$svc"
        fi
    done
    systemctl --user daemon-reload 2>/dev/null || true

    pkill -f "conky.*conky.conf" 2>/dev/null || true
    sleep 1

    echo -e "${RED}Eliminando configuración y artefactos...${NC}"
    rm -rf ~/.config/conky
    rm -rf "$INSTALL_DIR"

    echo -e "${GREEN}Eliminando paquetes conky...${NC}"
    sudo apt remove --purge -y conky conky-all 2>/dev/null || true
    sudo apt autoremove -y 2>/dev/null || true

    # Eliminar reglas sudoers añadidas
    if [[ -f "$SUDOERS_FILE" ]]; then
        sudo rm -f "$SUDOERS_FILE"
        log "sudoers file removed: $SUDOERS_FILE"
    fi

    # Eliminar servicios systemd del sistema
    remove_rkhunter_service 2>/dev/null || true

    dmsg "Desinstalación completa."
    log "Conky fully uninstalled."
}

########################################
# Control del servicio Conky
########################################

start_conky() {
    echo -e "${GREEN}Iniciando Conky...${NC}"
    if [[ -f ~/.config/systemd/user/conky.service ]]; then
        if systemctl --user start conky.service 2>/dev/null; then
            systemctl --user status conky.service --no-pager || true
            dmsg "Conky iniciado."
            log "conky.service started."
        else
            dmsg "Error al iniciar. Revisa: journalctl --user -u conky"
            return 1
        fi
    else
        dmsg "Servicio no encontrado. Instala Conky primero."
        return 1
    fi
}

stop_conky() {
    echo -e "${GREEN}Deteniendo Conky...${NC}"
    if [[ -f ~/.config/systemd/user/conky.service ]]; then
        if systemctl --user stop conky.service 2>/dev/null; then
            systemctl --user status conky.service --no-pager || true
            dmsg "Conky detenido."
            log "conky.service stopped."
        else
            dmsg "Error al detener."
            return 1
        fi
    else
        dmsg "Servicio no encontrado."
        return 1
    fi
}

restart_conky() {
    echo -e "${GREEN}Reiniciando Conky...${NC}"
    if [[ -f ~/.config/systemd/user/conky.service ]]; then
        if systemctl --user restart conky.service 2>/dev/null; then
            systemctl --user status conky.service --no-pager || true
            dmsg "Conky reiniciado."
            log "conky.service restarted."
        else
            dmsg "Error al reiniciar."
            return 1
        fi
    else
        dmsg "Servicio no encontrado."
        return 1
    fi
}

########################################
# RKHunter manual
########################################

check_rkhunter() {
    echo -e "${BLUE}Ejecutando RKHunter (manual)...${NC}"
    local warn_log="/tmp/rkhunter_warnings.txt"

    if ! sudo /usr/bin/rkhunter --update >/dev/null 2>&1; then
        log "WARNING: rkhunter --update failed."
        dmsg "No se pudo actualizar RKHunter (¿offline?).\nEscaneo con BD local."
    fi
    sudo /usr/bin/rkhunter --propupd >/dev/null 2>&1 || true

    local result_file
    result_file="$(mktemp /tmp/rkhunter_result.XXXXXX)"
    if sudo /usr/bin/rkhunter --check --sk >"$result_file" 2>/dev/null; then
        grep -iE "(warning|alert|suspect)" "$result_file" > "$warn_log" 2>/dev/null || touch "$warn_log"
        rm -f "$result_file"

        if [[ -s "$warn_log" ]]; then
            local count
            count="$(wc -l < "$warn_log")"
            dmsg "Scan completo: ${count} alerta(s).\nVer con: cat $warn_log"
            log "Manual scan: $count warnings."
        else
            dmsg "Sin alertas detectadas."
            rm -f "$warn_log"
            log "Manual scan: clean."
        fi
    else
        log "ERROR: rkhunter --check failed."
        dmsg "Error durante el escaneo."
        rm -f "$result_file"
        return 1
    fi
}

########################################
# Restauración de paquetes esenciales
########################################

restore_system() {
    if ! dconfirm "¿Restaurar paquetes esenciales del sistema?"; then
        dmsg "Restauración cancelada."
        return 1
    fi

    echo -e "${BLUE}Actualizando repositorios...${NC}"
    sudo apt update

    local -a essential_packages=(
        "ubuntu-desktop" "gdm3" "nautilus" "gvfs" "gvfs-backends"
        "gvfs-daemons" "gvfs-common" "ubuntu-standard" "ubuntu-minimal"
        "dbus-x11" "network-manager"
    )
    local note restored=0 skipped=0

    for pkg in "${essential_packages[@]}"; do
        case "$pkg" in
            ubuntu-desktop)  note="(Entorno de escritorio por defecto)";;
            gdm3)            note="(Gestor de Sesiones GNOME)";;
            nautilus)        note="(Administrador de archivos GNOME)";;
            gvfs)            note="(Sistema de archivos virtual GNOME)";;
            gvfs-backends)   note="(Backends para GVFS)";;
            gvfs-daemons)    note="(Daemons para GVFS)";;
            gvfs-common)     note="(Archivos comunes GVFS)";;
            ubuntu-standard) note="(Paquetes estándar Ubuntu)";;
            ubuntu-minimal)  note="(Paquetes mínimos Ubuntu)";;
            dbus-x11)        note="(Soporte X11 para DBus)";;
            network-manager) note="(Gestor de conexiones de red)";;
            *)               note="";;
        esac

        if dconfirm "¿Reinstalar $pkg $note?"; then
            if sudo apt install -y "$pkg"; then
                ((restored++)) || true
                log "Restored: $pkg"
            else
                log "ERROR restoring $pkg"
            fi
        else
            ((skipped++)) || true
            echo -e "${YELLOW}Saltando $pkg.${NC}"
            log "Skipped: $pkg"
        fi
    done

    if dconfirm "¿Ejecutar 'sudo apt --fix-broken install -y' para dependencias rotas?"; then
        sudo apt --fix-broken install -y || log "WARNING: fix-broken reported errors"
    else
        echo -e "${YELLOW}Saltando fix-broken.${NC}"
    fi

    # Google Chrome con descarga en directorio temporal aislado
    if ! dpkg -s google-chrome-stable &>/dev/null; then
        if dconfirm "Chrome no instalado. ¿Instalarlo?"; then
            local tmp_dl
            tmp_dl="$(mktemp -d)"
            if wget -q --timeout=30 \
                 https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb \
                 -O "$tmp_dl/google-chrome-stable_current_amd64.deb"; then
                sudo dpkg -i "$tmp_dl/google-chrome-stable_current_amd64.deb" \
                    || sudo apt -f install -y
                log "Chrome installed."
            else
                dmsg "Descarga de Chrome falló (¿offline?)."
                log "ERROR: Chrome download failed."
            fi
            rm -rf "$tmp_dl"
        else
            echo -e "${YELLOW}Saltando Chrome.${NC}"
        fi
    else
        if dconfirm "Chrome ya instalado. ¿Reinstalar?"; then
            sudo apt install --reinstall -y google-chrome-stable || true
            log "Chrome reinstalled."
        else
            echo -e "${YELLOW}Chrome conservado.${NC}"
        fi
    fi

    dmsg "Restauración completada.\nRestaurados: $restored | Saltados: $skipped"
    log "restore_system: restored=$restored skipped=$skipped"
}

########################################
# Visualizar log de aplicación
########################################

view_log() {
    if [[ -f "$LOGFILE" && -s "$LOGFILE" ]]; then
        dialog --textbox "$LOGFILE" 24 80
    else
        dmsg "Aún no hay log disponible en $LOGFILE"
    fi
}

########################################
# Menú principal
########################################

main_menu() {
    local choice
    while true; do
        local banner
        banner=$(printf "%s\n%s\n%s\n%s\n%s\n\n%s" \
            "  ____                _           " \
            " / ___|___  _ __  ___| |__   ___  " \
            "| |   / _ \\| '_ \\/ __| '_ \\ / _ \\ " \
            "| |__| (_) | | | \\__ \\ | | |  __/ " \
            " \\____\\___/|_| |_|___/_| |_|\\___| " \
            " Cybersecurity Monitor")

        dialog --clear --title "Bienvenido a Conky Cybersecurity Monitor" \
            --msgbox "$banner" 14 60

        choice=$(dmenu "Menú Principal" \
            1  "Instalar Conky" \
            2  "Desinstalar Conky" \
            3  "Iniciar Conky" \
            4  "Detener Conky" \
            5  "Reiniciar Conky" \
            6  "Ejecutar RKHunter (Manual)" \
            7  "Restaurar Paquetes Esenciales" \
            8  "Instalar Timer Automático RKHunter" \
            9  "Eliminar Timer Automático RKHunter" \
            10 "Ver Log de la Aplicación" \
            11 "Salir") || continue

        case "$choice" in
            1)  install_conky ;;
            2)  uninstall_conky ;;
            3)  start_conky ;;
            4)  stop_conky ;;
            5)  restart_conky ;;
            6)  check_rkhunter ;;
            7)  restore_system ;;
            8)  install_rkhunter_service ;;
            9)  remove_rkhunter_service ;;
            10) view_log ;;
            11)
                dmsg "¡Adiós! 🔒"
                clear
                exit 0
                ;;
            *)
                dmsg "Opción inválida."
                ;;
        esac
    done
}

########################################
# Entry point
########################################

main() {
    bootstrap_dialog
    mkdir -p "$INSTALL_DIR"
    log "=== Conky Cybersecurity Monitor iniciado (PID $$, user $USER) ==="
    acquire_sudo
    main_menu
}

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
